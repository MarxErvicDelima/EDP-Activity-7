<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EDPSystem.Views.UserManagementWindow"
        Title="User Management" 
        Height="800" Width="1200"
        Background="#0a0e27"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1a1f3a" BorderBrush="#00F3FF" BorderThickness="0,0,0,2" Padding="20" Margin="0,0,0,20">
            <TextBlock Text="User Management System" FontSize="28" FontWeight="Bold" Foreground="#00F3FF"/>
        </Border>

        <!-- Main Content Tabs -->
        <TabControl Grid.Row="1">
            <!-- User List Tab -->
            <TabItem Header="User List">
                <Grid Background="#0a0e27">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Search Bar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" Spacing="10">
                        <TextBlock Text="Search:" VerticalAlignment="Center" Foreground="#BC13FE"/>
                        <TextBox Width="300" Padding="8" Text="{Binding SearchTerm}" 
                                 Background="#1a1f3a" Foreground="#e0e0e0" BorderBrush="#00F3FF" BorderThickness="1"/>
                        <Button Content="Search" Padding="15,8" Background="#BC13FE" Foreground="#0a0e27" 
                                Click="SearchButton_Click" FontWeight="Bold"/>
                        <Button Content="Refresh" Padding="15,8" Background="#00F3FF" Foreground="#0a0e27" 
                                Click="RefreshButton_Click" FontWeight="Bold"/>
                    </StackPanel>

                    <!-- Users ListBox -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}"
                              Background="#1a1f3a" Foreground="#e0e0e0"
                              BorderBrush="#00F3FF" BorderThickness="1" Margin="10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#00F3FF" BorderThickness="0,0,0,1" Padding="10">
                                    <Grid ColumnDefinitions="120,100,100,150,80,130,130">
                                        <TextBlock Text="{Binding Username}" Foreground="#00F3FF" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding FirstName}" Foreground="#e0e0e0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding LastName}" Foreground="#e0e0e0"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Email}" Foreground="#BC13FE"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Status}" Foreground="#00AA00"/>
                                        <TextBlock Grid.Column="5" Text="{Binding CreatedAt, StringFormat=g}" Foreground="#e0e0e0" FontSize="10"/>
                                        <TextBlock Grid.Column="6" Text="{Binding LastLogin, StringFormat=g}" Foreground="#e0e0e0" FontSize="10"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Edit/Action Panel -->
                    <Border Grid.Row="2" Background="#1a1f3a" BorderBrush="#BC13FE" BorderThickness="1" Margin="10" Padding="15">
                        <StackPanel>
                            <TextBlock Text="Edit Selected User" FontSize="16" FontWeight="Bold" Foreground="#BC13FE" Margin="0,0,0,10"/>
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                <TextBlock Text="First Name:" Foreground="#00F3FF" Margin="0,0,10,5"/>
                                <TextBox Grid.Column="1" Text="{Binding EditFirstName}" Padding="8" Background="#0a0e27" 
                                         Foreground="#e0e0e0" BorderBrush="#00F3FF" BorderThickness="1" Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="1" Text="Last Name:" Foreground="#00F3FF" Margin="0,0,10,5"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditLastName}" Padding="8" Background="#0a0e27" 
                                         Foreground="#e0e0e0" BorderBrush="#00F3FF" BorderThickness="1" Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="2" Text="Email:" Foreground="#00F3FF" Margin="0,0,10,5"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding EditEmail}" Padding="8" Background="#0a0e27" 
                                         Foreground="#e0e0e0" BorderBrush="#00F3FF" BorderThickness="1" Margin="0,0,0,10"/>

                                <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="10">
                                    <Button Content="Update User" Padding="15,8" Background="#00F3FF" Foreground="#0a0e27" 
                                            Click="UpdateButton_Click" FontWeight="Bold"/>
                                    <Button Content="Activate" Padding="15,8" Background="#00AA00" Foreground="White" 
                                            Click="ActivateButton_Click" FontWeight="Bold"/>
                                    <Button Content="Deactivate" Padding="15,8" Background="#FF6600" Foreground="White" 
                                            Click="DeactivateButton_Click" FontWeight="Bold"/>
                                    <Button Content="Delete User" Padding="15,8" Background="#FF0000" Foreground="White" 
                                            Click="DeleteButton_Click" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Status Message -->
                    <Border Grid.Row="3" Background="#1a1f3a" BorderBrush="#FF006E" BorderThickness="1" Margin="10" Padding="10">
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#FF006E" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Add User Tab -->
            <TabItem Header="Add New User">
                <Grid Background="#0a0e27">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400" Margin="20">
                        <TextBlock Text="Create New User Account" FontSize="20" FontWeight="Bold" Foreground="#00F3FF" Margin="0,0,0,20"/>

                        <TextBlock Text="Username:" Foreground="#BC13FE" Margin="0,0,0,5"/>
                        <TextBox Padding="10" Text="{Binding NewUsername}" Background="#1a1f3a" Foreground="#e0e0e0" 
                                 BorderBrush="#00F3FF" BorderThickness="1" Margin="0,0,0,15"/>

                        <TextBlock Text="First Name:" Foreground="#BC13FE" Margin="0,0,0,5"/>
                        <TextBox Padding="10" Text="{Binding NewFirstName}" Background="#1a1f3a" Foreground="#e0e0e0" 
                                 BorderBrush="#00F3FF" BorderThickness="1" Margin="0,0,0,15"/>

                        <TextBlock Text="Last Name:" Foreground="#BC13FE" Margin="0,0,0,5"/>
                        <TextBox Padding="10" Text="{Binding NewLastName}" Background="#1a1f3a" Foreground="#e0e0e0" 
                                 BorderBrush="#00F3FF" BorderThickness="1" Margin="0,0,0,15"/>

                        <TextBlock Text="Email:" Foreground="#BC13FE" Margin="0,0,0,5"/>
                        <TextBox Padding="10" Text="{Binding NewEmail}" Background="#1a1f3a" Foreground="#e0e0e0" 
                                 BorderBrush="#00F3FF" BorderThickness="1" Margin="0,0,0,15"/>

                        <TextBlock Text="Password:" Foreground="#BC13FE" Margin="0,0,0,5"/>
                        <TextBox x:Name="PasswordBox" Padding="10" Background="#1a1f3a" Foreground="#e0e0e0" 
                                 BorderBrush="#00F3FF" BorderThickness="1" Margin="0,0,0,20"/>

                        <Button Content="Create Account" Padding="20,12" Background="#00F3FF" Foreground="#0a0e27" 
                                Click="CreateUserButton_Click" FontWeight="Bold" FontSize="14"/>

                        <Border Background="#1a1f3a" BorderBrush="#FF006E" BorderThickness="1" Margin="0,20,0,0" Padding="10">
                            <TextBlock Text="{Binding StatusMessage}" Foreground="#FF006E" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Password Recovery Tab -->
            <TabItem Header="Password Recovery">
                <Grid Background="#0a0e27">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="500" Margin="20">
                        <TextBlock Text="Password Recovery" FontSize="20" FontWeight="Bold" Foreground="#00F3FF" Margin="0,0,0,20"/>

                        <TextBlock Text="Step 1: Request Password Reset" FontSize="14" FontWeight="Bold" Foreground="#BC13FE" Margin="0,0,0,10"/>
                        <TextBlock Text="Username:" Foreground="#BC13FE" Margin="0,0,0,5"/>
                        <TextBox Padding="10" Text="{Binding RecoveryUsername}" Background="#1a1f3a" Foreground="#e0e0e0" 
                                 BorderBrush="#00F3FF" BorderThickness="1" Margin="0,0,0,10"/>
                        <Button Content="Request Reset Token" Padding="20,10" Background="#BC13FE" Foreground="#0a0e27" 
                                Click="RequestResetButton_Click" FontWeight="Bold" Margin="0,0,0,20"/>

                        <Separator Background="#00F3FF" Margin="0,20" Height="2"/>

                        <TextBlock Text="Step 2: Reset Password with Token" FontSize="14" FontWeight="Bold" Foreground="#BC13FE" Margin="0,20,0,10"/>
                        <TextBlock Text="Reset Token:" Foreground="#BC13FE" Margin="0,0,0,5"/>
                        <TextBox Padding="10" Text="{Binding ResetToken}" Background="#1a1f3a" Foreground="#e0e0e0" 
                                 BorderBrush="#00F3FF" BorderThickness="1" Margin="0,0,0,10" Height="60" TextWrapping="Wrap"/>

                        <TextBlock Text="New Password:" Foreground="#BC13FE" Margin="0,10,0,5"/>
                        <TextBox x:Name="ResetPasswordBox" Padding="10" Background="#1a1f3a" Foreground="#e0e0e0" 
                                 BorderBrush="#00F3FF" BorderThickness="1" Margin="0,0,0,10"/>

                        <TextBlock Text="Confirm Password:" Foreground="#BC13FE" Margin="0,0,0,5"/>
                        <TextBox x:Name="ConfirmResetPasswordBox" Padding="10" Background="#1a1f3a" Foreground="#e0e0e0" 
                                 BorderBrush="#00F3FF" BorderThickness="1" Margin="0,0,0,10"/>

                        <Button Content="Reset Password" Padding="20,10" Background="#00AA00" Foreground="White" 
                                Click="ResetPasswordButton_Click" FontWeight="Bold" FontSize="14"/>

                        <Border Background="#1a1f3a" BorderBrush="#FF006E" BorderThickness="1" Margin="0,20,0,0" Padding="10">
                            <TextBlock Text="{Binding StatusMessage}" Foreground="#FF006E" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
